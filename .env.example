# --- Serveur Minecraft existant ---
# Nom DNS Docker ou IP du serveur Minecraft vu depuis MCServer-panel.
# Si le conteneur Minecraft est raccorde au meme reseau Docker, garder minecraft.
SERVER=minecraft
RCON_PORT=25575
RCON_PASSWORD=change-this-rcon-password
MC_CONTAINER_NAME=minecraft
PANEL_CONTAINER_NAME=MCServer-panel

# Reseau Docker commun entre le serveur Minecraft existant et MCServer-panel.
MC_DOCKER_NETWORK=minecraft_default

# Volume monde existant du serveur Minecraft.
MC_WORLD_PATH=/volume1/docker/minecraft/data/world-26-2

# Volume persistant propre a MCServer-panel.
# Contient PocketBase : comptes, roles, preferences, audit et donnees applicatives.
PANEL_DATA_PATH=/volume1/docker/MCServer-panel/data

# --- MCServer-panel runtime ---
APP_PORT=8080
PUBLIC_URL=
TZ=Europe/Paris
UPLOAD_LIMIT_MB=64
LOG_TAIL_LINES=400
DOCKER_SOCKET_PATH=/var/run/docker.sock
ALLOW_STOP_SERVER=false
REQUIRE_AUTH=true

# --- PocketBase integre ---
POCKETBASE_URL=http://127.0.0.1:8090
PB_SUPERUSER_EMAIL=admin@example.local
PB_SUPERUSER_PASSWORD=change-this-admin-password
PANEL_ADMIN_EMAIL=admin@example.local
PANEL_ADMIN_PASSWORD=change-this-panel-password

# --- Image du panel ---
# Une seule variable a changer pour tirer une nouvelle image sur Synology.
PANEL_IMAGE_TAG=1.1.18

# --- Catalogue externe optionnel ---
# Recherche Modrinth active par defaut. Decommenter pour couper les appels externes.
# CATALOG_DISABLED=true
ENABLE_CATALOG_INSTALL=false
