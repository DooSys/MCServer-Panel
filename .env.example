# --- Acces au serveur Minecraft existant ---
# Ce projet ne gere pas le conteneur itzg/minecraft-server.
# Le conteneur MCServer-panel doit seulement pouvoir joindre RCON et lire le volume monde.
MC_DOCKER_NETWORK=MCServer-panel-net
MC_WORLD_PATH=/volume1/docker/minecraft/data/world-26-2
MC_RCON_HOST=minecraft
MC_RCON_PORT=25575
MC_RCON_PASSWORD=change-this-rcon-password

# --- Informations affichees par le panel ---
MC_DATA_PATH=/mc-data
MC_SERVER_FLAVOR=Vanilla
MC_VERSION=26.2
MC_DOCKER_IMAGE=itzg/minecraft-server
MC_DOCKER_TAG=latest
ENABLE_IMAGE_UPDATE_CHECK=false

# --- MCServer-panel runtime ---
APP_PORT=8080
PUBLIC_URL=
TZ=Europe/Paris
UPLOAD_LIMIT_MB=64
ALLOW_STOP_SERVER=false
REQUIRE_AUTH=true

# --- PocketBase integre ---
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_DATA=/app/pb_data
PANEL_PB_DATA_PATH=/volume1/docker/MCServer-panel/pb_data
PB_SUPERUSER_EMAIL=admin@example.local
PB_SUPERUSER_PASSWORD=change-this-admin-password
PANEL_ADMIN_EMAIL=admin@example.local
PANEL_ADMIN_PASSWORD=change-this-panel-password

# --- Version / image du panel ---
APP_VERSION=1.1.2
APP_DOCKER_IMAGE=ghcr.io/doosys/mcserver-panel
APP_DOCKER_TAG=latest
PANEL_UPDATE_STATUS=not_checked

# --- Catalogue externe optionnel ---
ENABLE_CATALOG=false
ENABLE_CATALOG_INSTALL=false
CATALOG_USER_AGENT=MCServer-Panel/1.1.2
